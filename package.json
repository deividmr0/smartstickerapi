{
  "name": "smartsticker",
  "version": "1.0.0",
  "description": "API Núcleo B2B (Fastify) para integración con Tracksolid Pro",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier -w .",
    "knex": "tsx node_modules/knex/bin/cli.js --knexfile knexfile.ts",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:make": "npm run knex -- migrate:make",
    "seed:run": "npm run knex -- seed:run",
    "creds:set": "tsx scripts/set-zone-credentials.ts",
    "apikeys:generate": "tsx scripts/generate-api-keys.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.48",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "knex": "^3.1.0",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
