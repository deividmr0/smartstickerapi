NODE_ENV=development

HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Cifrado para secretos en DB (32 bytes en base64)
# En PowerShell: [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))
ENCRYPTION_KEY_B64=replace_me

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smartsticker
DB_PASSWORD=smartsticker
DB_NAME=smartsticker

# Caché (segundos)
DEVICES_CACHE_TTL_SECONDS=900
LOCATIONS_CACHE_TTL_SECONDS=300

# Proveedor: mock | tracksolid
PROVIDER_MODE=mock

# --- Solo para cargar credenciales Tracksolid en DB (script) ---
# Ejecuta: npm run creds:set
# Requiere definir:
ZONE_CODE=us
JIMI_USER_ID=
JIMI_USER_PWD_MD5=
JIMI_APP_KEY=
JIMI_APP_SECRET=

